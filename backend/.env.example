## Backend environment variables (example)
## Copy to `backend/.env` for local dev (never commit real secrets).

# Required (LLM)
ANTHROPIC_API_KEY=

# Optional (live scraping providers)
ZENROWS_API_KEY=
SCRAPINGBEE_API_KEY=

# Optional (debug)
PARTSELECT_DEBUG=false
ANTHROPIC_API_KEY=your_key_here
